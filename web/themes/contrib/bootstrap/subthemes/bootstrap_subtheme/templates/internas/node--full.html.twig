#additional-carousel .owl-stage {
  display: flex;
  align-items: center;
}


#additional-carousel .owl-item {
  display: flex;
  justify-content: center;
}
*/

.share-product{
    width: 100%;
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 5em;
    flex-wrap: wrap;
    height: 5em;
}

.share-title{
  font-weight:600;
  margin-right:5px;
}

.share-btn{
  width:36px;
  height:36px;
  display:flex;
  align-items:center;
  justify-content:center;
  border-radius:50%;
  color:#fff;
  font-size:16px;
  text-decoration:none;
  transition:0.3s;
}

.share-btn.facebook{
  background:#1877f2;
}

.share-btn.twitter{
  background:#1da1f2;
}

.share-btn.instagram{
  background:#e4405f;
}

.share-btn:hover{
  transform:scale(1.1);
}

/* Responsive */
@media (max-width:768px){
  .share-product{
    justify-content:center;
  }
}
</style>

{{ attach_library('bootstrap_subtheme/product-gallery') }}
{{ attach_library('bootstrap/node') }}
{{ attach_library('bootstrap_subtheme/global-styling') }}