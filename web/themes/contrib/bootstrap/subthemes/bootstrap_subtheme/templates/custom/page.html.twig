           <script>
           //------------------
document.addEventListener("DOMContentLoaded", function() {
  const sidebar = document.querySelector("#sidebar");
  const container = document.querySelector(".my-container");
  const closeBtn = document.querySelector("#close-btn");
  const menuButtons = document.querySelectorAll("#menu-btn, #menu-btn-mobile");

  // Abrir sidebar al hacer clic en cualquier botón
  menuButtons.forEach(btn => {
    btn.addEventListener("click", function(e) {
      e.preventDefault();
      e.stopPropagation();
      sidebar.classList.add("open");
      container.classList.add("shift");
    });
  });

  // Cerrar sidebar
  if (closeBtn) {
    closeBtn.addEventListener("click", function() {
      sidebar.classList.remove("open");
      container.classList.remove("shift");
    });
  }

  // Click fuera del sidebar cierra
  document.addEventListener("click", function(e) {
    if (!sidebar.contains(e.target) && ![...menuButtons].some(btn => btn.contains(e.target))) {
      sidebar.classList.remove("open");
      container.classList.remove("shift");
    }
  });
});

           //-------------------
                    document.addEventListener("DOMContentLoaded", function () {

                      const accountWrapper = document.querySelector(".myaccount");
                      const accountToggle = document.querySelector(".myaccount > .dropdown-toggle");
                      const accountMenu = document.querySelector(".myaccount-menu");

                      const searchWrapper = document.querySelector("#search");
                      const searchButton = document.querySelector("#search .search_button");
                      const searchToggle = document.querySelector("#search .search_toggle");

                      const toggle = document.querySelector(".nav-responsive");
                      const menu = document.querySelector(".main-navigation");

                      const cartWrapper = document.querySelector("#cart");

                      // ===== Cuenta =====
                      if (accountToggle && accountMenu) {
                        accountToggle.addEventListener("click", function(e){
                          e.preventDefault();
                          e.stopPropagation();
                          accountMenu.classList.toggle("open");
                        });
                      }

                      // ===== Buscador =====
                      if (searchButton && searchToggle) {
                        searchButton.addEventListener("click", function(e){
                          e.stopPropagation();
                          searchToggle.classList.toggle("open");

                          const input = searchToggle.querySelector("input");
                          if (input) input.focus();
                        });
                      }

                      // ===== Menú móvil =====
                      if (toggle && menu) {
                        toggle.addEventListener("click", function(e){
                          e.stopPropagation();
                          menu.classList.toggle("open");
                        });
                      }

                      // ===== Evitar conflicto con carrito =====
                      if (cartWrapper) {
                        cartWrapper.addEventListener("click", function(e){
                          e.stopPropagation();
                        });
                      }

                      // ===== Click fuera =====
                      document.addEventListener("click", function(e){

                        if (accountWrapper && !accountWrapper.contains(e.target)) {
                          accountMenu.classList.remove("open");
                        }

                        if (searchWrapper && !searchWrapper.contains(e.target)) {
                          searchToggle.classList.remove("open");
                        }

                        if (menu && toggle && !menu.contains(e.target) && !toggle.contains(e.target)) {
                          menu.classList.remove("open");
                        }

                      });

                    });
             </script>
